# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=dairycare
DB_USER=dairycare
DB_PASSWORD=dairycare_dev
DB_HOST=db
DB_PORT=5432

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Production: ALLOWED_HOSTS=app.dusuq.com,24.144.103.213
# (the bare IP is included so nginx's IP-fallback server block — see
# nginx/nginx.prod.conf — can reach Django before/without DNS)

# CORS — who's allowed to call the API cross-origin. In production this is the
# marketing site (dusuq.com), which submits the contact form and support tickets
# to app.dusuq.com. The app itself doesn't need to be listed — it's same-origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production: CORS_ALLOWED_ORIGINS=https://dusuq.com,https://www.dusuq.com

# CSRF — required for Django admin to work behind the nginx reverse proxy.
CSRF_TRUSTED_ORIGINS=http://localhost:8000
# Production: CSRF_TRUSTED_ORIGINS=https://app.dusuq.com,http://24.144.103.213,https://24.144.103.213

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Baked into the React build at build time.
VITE_API_URL=http://localhost:80
# Production: leave this UNSET (remove the line, or comment it out) so it
# resolves to a relative /api — frontend and API are always same-origin behind
# nginx here, whether accessed by domain or bare IP. Only set an absolute URL
# if the frontend is ever served from a different host than the API.

# ─── VetAssist (Gemini API) ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Production only (leave blank in dev) ─────────────────────────────────────
# SSL_EMAIL is used for the Let's Encrypt certificate (see VPS_DEPLOYMENT.md).
SSL_EMAIL=

# Which nginx config to use — nginx.prod.conf (needs a real cert + DNS pointed
# at this server) or nginx.no-ssl.conf (plain HTTP, no cert or DNS required —
# use this to get running immediately, switch to nginx.prod.conf later).
NGINX_CONF=nginx.no-ssl.conf

# Set to True once you're on nginx.prod.conf with a real cert. False (the
# default here) means Django won't force HTTPS redirects or secure-only
# cookies — required for the app to work at all over plain HTTP.
USE_HTTPS=False
