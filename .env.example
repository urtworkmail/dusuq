# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=dairycare
DB_USER=dairycare
DB_PASSWORD=dairycare_dev
DB_HOST=db
DB_PORT=5432

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Production: ALLOWED_HOSTS=erp.dusuq.com

# CORS — who's allowed to call the API cross-origin. In production this is the
# marketing site (dusuq.com), which submits the contact form and support tickets
# to erp.dusuq.com. The app itself doesn't need to be listed — it's same-origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production: CORS_ALLOWED_ORIGINS=https://dusuq.com,https://www.dusuq.com

# CSRF — required for Django admin to work behind the nginx reverse proxy.
CSRF_TRUSTED_ORIGINS=http://localhost:8000
# Production: CSRF_TRUSTED_ORIGINS=https://erp.dusuq.com

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Baked into the React build at build time. In production this is the app's own
# origin (erp.dusuq.com) — frontend and API are served from the same host via nginx.
VITE_API_URL=http://localhost:80
# Production: VITE_API_URL=https://erp.dusuq.com

# ─── VetAssist (Gemini API) ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Production only (leave blank in dev) ─────────────────────────────────────
# nginx/nginx.prod.conf is hardcoded for dusuq.com (marketing) + erp.dusuq.com (app) —
# no templating needed. SSL_EMAIL is used for the Let's Encrypt certificate below.
SSL_EMAIL=
